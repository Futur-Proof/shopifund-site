{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "shopifund-site.vercel.app" }],
      "destination": "https://shopifund.com/$1",
      "permanent": true
    }
  ]
}
